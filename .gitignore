# Ignore everything by default
*

# ===== UN-IGNORE: Directories & files to track =====

# Theme
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/xanhdesignbuild/
!wp-content/themes/xanhdesignbuild/**

# Wireframes
!wireframes/
!wireframes/**

# Docs
!docs/
!docs/**

# Agent config
!.agent/
!.agent/**

# Config files
!.htaccess
!wp-config.php

# This gitignore itself
!.gitignore

# ===== ALWAYS IGNORE (even in un-ignored dirs) =====

# Node
**/node_modules/

# OS files
**/.DS_Store
**/Thumbs.db

# FTP deploy credentials
**/ftp-deploy.js

# Agent auto-generated skills cache
.agent/skills/skills

# WP backups
**/ai1wm-backups/
